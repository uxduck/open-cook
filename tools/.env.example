FAL_KEY=your-fal-api-key-here
FAL_MODEL_PRESET=quality
FOOD_ASSET_LIMIT=8
FOOD_ASSET_OUTPUT_DIR=apps/web/public/marketing-assets
FOOD_ASSET_RAW_DIR=artifacts/marketing-assets/raw
FOOD_ASSET_PUBLIC_FORMAT=webp

# Presets:
# - draft: fal-ai/flux/schnell
# - quality: fal-ai/nano-banana-pro
# - flux-pro: fal-ai/flux-pro/v1.1
# - ultra: fal-ai/flux-pro/v1.1-ultra
# - flux-2-pro: fal-ai/flux-2-pro
# - nano-banana-pro: fal-ai/nano-banana-pro
# - gpt-image-2: fal-ai/openai/gpt-image-2
#
# Override with a custom endpoint only when needed:
# FAL_MODEL=fal-ai/nano-banana-pro
# FAL_MODEL_MODE=image_size
# FAL_MODEL_BACKGROUND=neutral
#
# Background removal:
# - quality presets default to FOOD_ASSET_REMOVE_KEY=auto-border
# - draft/chroma presets default to each prompt's chroma key
# FOOD_ASSET_REMOVE_KEY=auto-border
