{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 88,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "node_modules",
    "artifacts",
    "dist",
    "**/dist",
    ".data",
    ".agents",
    ".claude",
    ".codex",
    "apps/web/src/routeTree.gen.ts",
    "**/.wrangler"
  ]
}
