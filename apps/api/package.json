{
  "name": "@open-cook/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm db:migrate:local && wrangler dev --env-file ../../.env $([ -f .env ] && echo --env-file .env) --local --port 8787",
    "build": "tsc --build",
    "deploy": "pnpm run deploy:production",
    "deploy:production": "pnpm run build && pnpm run db:migrate:remote && wrangler deploy --minify --env=production",
    "deploy:staging": "pnpm run build && pnpm run db:migrate:remote && wrangler deploy --minify --env=staging",
    "cf-preview": "pnpm run build && wrangler dev --env-file ../../.env $([ -f .env ] && echo --env-file .env)",
    "cf-preview:staging": "pnpm run build && wrangler dev --env-file ../../.env $([ -f .env ] && echo --env-file .env) --env=staging",
    "cf-typegen": "wrangler types",
    "emails:dev": "email dev --dir src/features/emails/templates --port 3005",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply open-cook --local",
    "db:migrate:remote": "wrangler d1 migrations apply open-cook --remote",
    "db:seed:local": "wrangler d1 execute open-cook --local --file seeds/dev-recipes.sql",
    "db:studio": "pnpm db:migrate:local && drizzle-kit studio",
    "db:studio:prod": "DRIZZLE_STUDIO_TARGET=production drizzle-kit studio",
    "db:studio:production": "pnpm db:studio:prod",
    "db:studio:staging": "DRIZZLE_STUDIO_TARGET=staging drizzle-kit studio",
    "typecheck": "tsc --build",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@better-auth/passkey": "^1.6.9",
    "@hono/standard-validator": "^0.2.0",
    "@hono/swagger-ui": "^0.6.0",
    "@open-cook/core": "workspace:*",
    "@paid-ai/paid-node": "^1.7.0",
    "@scalar/hono-api-reference": "^0.10.0",
    "@valibot/to-json-schema": "^1.5.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "hono-openapi": "^1.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.12.2",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260514.1",
    "@libsql/client": "^0.17.3",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.7",
    "drizzle-kit": "^0.31.9",
    "react-email": "^6.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.99.0"
  }
}
