{
  "name": "@open-cook/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "build:vercel": "OPEN_COOK_DEPLOY_TARGET=vercel vite build",
    "deploy": "pnpm run deploy:production",
    "deploy:production": "CLOUDFLARE_ENV=production pnpm run build && wrangler deploy",
    "deploy:staging": "CLOUDFLARE_ENV=staging pnpm run build && wrangler deploy",
    "cf-preview": "pnpm run build && vite preview",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --build",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@open-cook/core": "workspace:*",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@vitejs/plugin-react": "^5.1.3",
    "better-auth": "^1.6.9",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.99.0"
  }
}
